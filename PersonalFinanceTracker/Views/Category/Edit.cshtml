@model PersonalFinanceTracker.Models.Category

@{
    ViewData["Title"] = "Edit Category";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="row">
            <!-- Form Card -->
            <div class="col-md-7">
                <div class="custom-card">
                    <h3 class="mb-2"><span class="gradient-heading">Edit Category</span></h3>
                    <p class="text-secondary mb-4">Modify the settings for your category below.</p>

                    <form method="post" asp-action="Edit">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="CategoryId" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label">Category Name</label>
                            <input asp-for="Name" class="form-control" placeholder="e.g. Food, Rent, Salary" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Icon" class="form-label">Select Icon</label>
                            <input asp-for="Icon" class="form-control" id="iconInput" readonly required placeholder="Click an icon below to select..." />
                            <span asp-validation-for="Icon" class="text-danger"></span>
                            
                            <!-- Icon Picker Grid -->
                            <div class="icon-picker-grid">
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-wallet" title="Salary"><i class="fa-solid fa-wallet"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-briefcase" title="Business"><i class="fa-solid fa-briefcase"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-utensils" title="Food"><i class="fa-solid fa-utensils"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-house" title="Housing/Rent"><i class="fa-solid fa-house"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-car" title="Transport"><i class="fa-solid fa-car"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-shirt" title="Shopping"><i class="fa-solid fa-shirt"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-film" title="Entertainment"><i class="fa-solid fa-film"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-heart-pulse" title="Medical"><i class="fa-solid fa-heart-pulse"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-mobile-screen" title="Phone/Bills"><i class="fa-solid fa-mobile-screen"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-graduation-cap" title="Education"><i class="fa-solid fa-graduation-cap"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-plane" title="Travel"><i class="fa-solid fa-plane"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-gift" title="Gifts"><i class="fa-solid fa-gift"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-dumbbell" title="Sports"><i class="fa-solid fa-dumbbell"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-tools" title="Maintenance"><i class="fa-solid fa-tools"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-coins" title="Finance"><i class="fa-solid fa-coins"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-percent" title="Tax/Interest"><i class="fa-solid fa-percent"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-credit-card" title="Card"><i class="fa-solid fa-credit-card"></i></button>
                                <button type="button" class="icon-picker-btn" data-icon="fa-solid fa-tag" title="General"><i class="fa-solid fa-tag"></i></button>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Type" class="form-label">Type</label>
                            <select asp-for="Type" class="form-select">
                                <option value="Expense">Expense</option>
                                <option value="Income">Income</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-3 mt-5">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fa-solid fa-save me-2"></i>Save Changes
                            </button>
                            <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Side Card Info -->
            <div class="col-md-5">
                <div class="custom-card d-flex flex-column align-items-center justify-content-center text-center h-100 py-5">
                    <span class="d-inline-flex align-items-center justify-content-center bg-dark text-success rounded-circle mb-4" style="width: 75px; height: 75px; background-color: var(--accent-muted) !important;">
                        <i class="fa-solid fa-pen-fancy fs-1 text-success"></i>
                    </span>
                    <h4 class="text-white">Modify & Update</h4>
                    <p class="text-secondary px-3">
                        Updating the category type or icon changes will immediately cascade to all existing transactions that use this category on your dashboard.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const iconInput = document.getElementById('iconInput');
            const buttons = document.querySelectorAll('.icon-picker-btn');

            buttons.forEach(btn => {
                btn.addEventListener('click', () => {
                    buttons.forEach(b => b.classList.remove('selected'));
                    btn.classList.add('selected');
                    iconInput.value = btn.getAttribute('data-icon');
                });
            });

            // Pre-select if value is populated
            if (iconInput.value) {
                const preSelected = document.querySelector(`.icon-picker-btn[data-icon="${iconInput.value}"]`);
                if (preSelected) preSelected.classList.add('selected');
            }
        });
    </script>
}
