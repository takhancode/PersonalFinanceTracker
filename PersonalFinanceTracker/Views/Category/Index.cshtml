@model IEnumerable<PersonalFinanceTracker.Models.Category>

<h2>Categories</h2>
<a href="/Category/Create" class="btn btn-primary mb-3">+ Add Category</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Type</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Type</td>
            </tr>
        }
    </tbody>
</table>