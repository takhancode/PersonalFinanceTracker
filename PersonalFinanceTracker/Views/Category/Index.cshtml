@model IEnumerable<PersonalFinanceTracker.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="row">
    <!-- Left Column: Categories List -->
    <div class="col-lg-8">
        <div class="custom-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h3 class="mb-1"><span class="gradient-heading">Categories</span></h3>
                    <p class="text-secondary mb-0">Manage classifications for your income and expenses.</p>
                </div>
                <a href="/Category/Create" class="btn btn-primary">
                    <i class="fa-solid fa-plus me-2"></i>New Category
                </a>
            </div>

            <div class="table-responsive">
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th>Type</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-5">
                                    <i class="fa-solid fa-tags fs-1 d-block mb-3"></i>
                                    No categories added yet. Click "New Category" to start.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <span class="category-icon-wrapper @(item.Type == "Income" ? "category-icon-income" : "category-icon-expense")">
                                                <i class="@(string.IsNullOrEmpty(item.Icon) ? "fa-solid fa-tag" : item.Icon)"></i>
                                            </span>
                                            <span class="fw-semibold">@item.Name</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="@(item.Type == "Income" ? "badge-income" : "badge-expense")">
                                            <i class="fa-solid @(item.Type == "Income" ? "fa-arrow-trend-up" : "fa-arrow-trend-down") me-1"></i>
                                            @item.Type
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <a href="/Category/Edit/@item.CategoryId" class="btn btn-secondary btn-sm me-2" title="Edit Category">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        <a href="/Category/Delete/@item.CategoryId" class="btn btn-danger btn-sm" title="Delete Category">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Right Column: Info & Tips Guide -->
    <div class="col-lg-4">
        <div class="custom-card text-center py-4 px-3 mb-4">
            <div class="my-3">
                <span class="d-inline-flex align-items-center justify-content-center bg-dark text-success rounded-circle" style="width: 70px; height: 70px;">
                    <i class="fa-solid fa-circle-nodes fs-1 text-success"></i>
                </span>
            </div>
            <h4 class="text-white mt-3">Icon Library Tip</h4>
            <p class="text-secondary px-2">Customize your categories with FontAwesome icons to display them beautifully on your dashboard.</p>
        </div>

        <div class="custom-card">
            <h5 class="text-white mb-3">Popular Icon Codes</h5>
            <p class="text-muted small mb-3">Copy-paste any class code below when creating or editing categories:</p>
            
            <div class="d-flex flex-column gap-3">
                <div class="d-flex justify-content-between align-items-center border-bottom border-secondary pb-2">
                    <span class="text-secondary"><span class="category-icon-wrapper category-icon-income"><i class="fa-solid fa-wallet"></i></span> Salary</span>
                    <code class="text-success select-all">fa-solid fa-wallet</code>
                </div>
                <div class="d-flex justify-content-between align-items-center border-bottom border-secondary pb-2">
                    <span class="text-secondary"><span class="category-icon-wrapper category-icon-expense"><i class="fa-solid fa-utensils"></i></span> Food / Dining</span>
                    <code class="text-success select-all">fa-solid fa-utensils</code>
                </div>
                <div class="d-flex justify-content-between align-items-center border-bottom border-secondary pb-2">
                    <span class="text-secondary"><span class="category-icon-wrapper category-icon-expense"><i class="fa-solid fa-house"></i></span> Rent / Utilities</span>
                    <code class="text-success select-all">fa-solid fa-house</code>
                </div>
                <div class="d-flex justify-content-between align-items-center border-bottom border-secondary pb-2">
                    <span class="text-secondary"><span class="category-icon-wrapper category-icon-expense"><i class="fa-solid fa-car"></i></span> Transport</span>
                    <code class="text-success select-all">fa-solid fa-car</code>
                </div>
                <div class="d-flex justify-content-between align-items-center border-bottom border-secondary pb-2">
                    <span class="text-secondary"><span class="category-icon-wrapper category-icon-expense"><i class="fa-solid fa-shirt"></i></span> Shopping</span>
                    <code class="text-success select-all">fa-solid fa-shirt</code>
                </div>
                <div class="d-flex justify-content-between align-items-center pb-2">
                    <span class="text-secondary"><span class="category-icon-wrapper category-icon-expense"><i class="fa-solid fa-heart-pulse"></i></span> Health</span>
                    <code class="text-success select-all">fa-solid fa-heart-pulse</code>
                </div>
            </div>
        </div>
    </div>
</div>