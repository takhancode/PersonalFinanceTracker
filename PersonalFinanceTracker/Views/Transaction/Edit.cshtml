@model PersonalFinanceTracker.Models.Transaction

@{
    ViewData["Title"] = "Edit Transaction";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="row">
            <!-- Form Card -->
            <div class="col-md-7">
                <div class="custom-card">
                    <h3 class="mb-2 text-white">Edit Transaction</h3>
                    <p class="text-secondary mb-4">Modify the settings for your transaction below.</p>

                    <form method="post" asp-action="Edit">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="TransactionId" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Type" class="form-label">Transaction Type</label>
                                <select asp-for="Type" class="form-select">
                                    <option value="Expense">Expense</option>
                                    <option value="Income">Income</option>
                                </select>
                                <span asp-validation-for="Type" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="CategoryId" class="form-label">Category</label>
                                <select asp-for="CategoryId" class="form-select">
                                    @if (ViewBag.Categories != null)
                                    {
                                        @foreach (var cat in ViewBag.Categories)
                                        {
                                            <option value="@cat.CategoryId">@cat.Name (@cat.Type)</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Amount" class="form-label">Amount (Rs.)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-dark border-secondary text-secondary">Rs.</span>
                                    <input asp-for="Amount" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                                </div>
                                <span asp-validation-for="Amount" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Date" class="form-label">Transaction Date</label>
                                <input asp-for="Date" type="date" class="form-control" asp-format="{0:yyyy-MM-dd}" required />
                                <span asp-validation-for="Date" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label">Description / Note</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Add custom notes..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-3 mt-5">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="fa-solid fa-save me-2"></i>Save Changes
                            </button>
                            <a href="/Transaction/Index" class="btn btn-secondary px-4">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Side Card Info -->
            <div class="col-md-5">
                <div class="custom-card d-flex flex-column align-items-center justify-content-center text-center h-100 py-5">
                    <span class="d-inline-flex align-items-center justify-content-center bg-dark text-success rounded-circle mb-4" style="width: 75px; height: 75px;">
                        <i class="fa-solid fa-pen-to-square fs-1 text-success"></i>
                    </span>
                    <h4 class="text-white">Edit Records</h4>
                    <p class="text-secondary px-3">
                        Need to adjust details? Modifying your logged transactions immediately updates your dashboard widgets and category distribution charts.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
