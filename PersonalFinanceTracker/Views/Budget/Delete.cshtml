@model PersonalFinanceTracker.Models.Budget

@{
    ViewData["Title"] = "Delete Budget Limit";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="custom-card border border-danger">
            <div class="text-center my-3">
                <span class="d-inline-flex align-items-center justify-content-center bg-danger-subtle text-danger rounded-circle" style="width: 70px; height: 70px; background-color: rgba(239, 68, 68, 0.15)">
                    <i class="fa-solid fa-triangle-exclamation fs-1 text-danger"></i>
                </span>
            </div>
            
            <h3 class="text-white text-center mt-3 mb-2">Delete Budget Limit?</h3>
            <p class="text-secondary text-center px-3 mb-4">
                Are you sure you want to delete this budget limit? This action cannot be undone.
            </p>

            <div class="bg-dark p-3 rounded mb-4">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-secondary">Category:</span>
                    <span class="text-white fw-bold">@(Model.Category?.Name ?? "General Expense")</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-secondary">Month & Year:</span>
                    <span class="text-white fw-semibold">
                        @{
                            var parsedDateStr = Model.MonthYear;
                            if (DateTime.TryParseExact(Model.MonthYear, "yyyy-MM", null, System.Globalization.DateTimeStyles.None, out var dateParsed))
                            {
                                parsedDateStr = dateParsed.ToString("MMMM yyyy");
                            }
                        }
                        @parsedDateStr
                    </span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-secondary">Limit Amount:</span>
                    <span class="text-danger fw-bold">Rs. @Model.LimitAmount.ToString("N2")</span>
                </div>
            </div>

            <form method="post" asp-action="Delete">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="BudgetId" />
                
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-danger w-50">
                        <i class="fa-solid fa-trash-can me-2"></i>Confirm Delete
                    </button>
                    <a href="/Budget/Index" class="btn btn-secondary w-50 text-center">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
